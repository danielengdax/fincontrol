# ================================
# FINCONTROL — .env.example
# ================================
# Copie este arquivo para .env e preencha os valores

# --- BANCO DE DADOS ---
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fincontrol

# --- JWT ---
JWT_SECRET=troque_por_uma_string_aleatoria_longa_aqui_min64chars

# --- STRIPE ---
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Crie os preços em: https://dashboard.stripe.com/products
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# --- SENDGRID ---
# Obtenha em: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....

# --- APP ---
APP_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
